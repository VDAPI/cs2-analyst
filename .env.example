# ─── Database & Cache ────────────────────────────────────
DATABASE_URL="postgresql://cs2analyst:cs2analyst@localhost:5432/cs2analyst"
REDIS_URL="redis://localhost:6379"

# ─── NextAuth ────────────────────────────────────────────
# Dev uses https via `next dev --experimental-https` (self-signed cert).
NEXTAUTH_URL="https://localhost:3000"
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Dev only: allow self-signed cert for server-side fetches. Do NOT set in prod.
NODE_TLS_REJECT_UNAUTHORIZED="0"
# Set to "1" to expose the dev credentials login shortcut.
NEXT_PUBLIC_DEV_LOGIN="0"

# ─── Steam ───────────────────────────────────────────────
# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
# Used as the clientSecret for Steam OpenID login in src/app/api/auth/[...nextauth]/route.ts
STEAM_API_KEY=""

# ─── FACEIT ──────────────────────────────────────────────
# Data API key (server-side) — https://developers.faceit.com
FACEIT_API_KEY=""
# Downloads API key. The grant extended the Data API key, but it's kept
# separate for future-proofing. Currently the same value as FACEIT_API_KEY.
FACEIT_DOWNLOADS_API_KEY=""
# OAuth2 app credentials for the manual FACEIT link flow (/api/faceit/link)
FACEIT_CLIENT_ID=""
FACEIT_CLIENT_SECRET=""
# Shared secret for the demo-ready webhook (x-faceit-webhook-secret header).
# Generate one with: openssl rand -hex 32
FACEIT_WEBHOOK_SECRET=""

# ─── Cloudflare R2 (S3-compatible storage) ───────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://localhost:3000"
NEXT_PUBLIC_APP_NAME="CS2 Analyst"
